### PROJECT SETTINGS

PROJECT_NAME=sita-membership_project
PROJECT_BASE_URL=sita-membership.example.com
APP_URL=https://${PROJECT_BASE_URL}

APP_KEY=CHANGE_ME_TO_SECURE_32_CHAR_KEY

DB_NAME=laravel_prod
DB_USER=laravel_prod
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_TO_SECURE_ROOT_PASSWORD
# DB_HOST=mariadb
# DB_PORT=3306
# DB_DRIVER=mysql


### CADDY SSL
# Caddy automatically handles Let's Encrypt SSL certificate generation and renewal.
# Set EMAIL to receive expiry notifications from Let's Encrypt.
# Set PROJECT_BASE_URL to your production domain (no protocol prefix).
# Set CADDY_TAG to pin a specific Caddy image version (see https://hub.docker.com/_/caddy).

EMAIL=admin@example.com
CADDY_TAG=2.11.4